# Web app env vars (Next.js auto-loads apps/web/.env at dev/build time).
# For the full reference covering all apps + Wrangler secrets, see ../../.env.example

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key
CLERK_SECRET_KEY=sk_test_your-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_AGENTS_URL=https://jobric-agents.YOUR_SUBDOMAIN.workers.dev
