# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Google OAuth (for Gmail API + user login) ─────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/auth/callback/google

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ── Redis (Upstash) ───────────────────────────────────────
REDIS_URL=rediss://your-upstash-redis-url

# ── API Server ────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=a-random-string-minimum-32-characters-long

# ── Monitoring (can leave blank in development) ───────────
SENTRY_DSN=https://your-sentry-dsn
AXIOM_TOKEN=your-axiom-token
AXIOM_DATASET=jobric-api