# ── Supabase ──────────────────────────────────────────────
# Get these from your Supabase project dashboard:
# https://app.supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Supabase (client-side, Next.js only) ─────────────────
# Same values as above, prefixed for Next.js client exposure
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Google OAuth (for Gmail API + user login) ─────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# 1. Create an OAuth 2.0 Client ID (Web application type)
# 2. Set the authorized redirect URI to match GOOGLE_REDIRECT_URI below
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/auth/callback/google

# ── OpenAI ────────────────────────────────────────────────
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ── Redis (Upstash) ──────────────────────────────────────
# Create a database at https://console.upstash.com
# Copy the REST URL (starts with https://) or Redis URL (starts with rediss://)
REDIS_URL=rediss://your-upstash-redis-url

# ── API Server ────────────────────────────────────────────
# Port the API server listens on (default: 3001)
PORT=3001
# Runtime environment — must be one of: development, staging, production
NODE_ENV=development
# Used to sign JWTs — generate with: openssl rand -base64 48
# Must be at least 32 characters
JWT_SECRET=a-random-string-minimum-32-characters-long

# ── Monitoring (optional, can leave blank in development) ─
# Sentry: https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=https://your-sentry-dsn
# Axiom: https://app.axiom.co → Settings → API Tokens
AXIOM_TOKEN=your-axiom-token
AXIOM_DATASET=jobric-api
