# ── Clerk ─────────────────────────────────────────────────
# Get these from your Clerk Dashboard:
# https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key
CLERK_SECRET_KEY=sk_test_your-key

# ── Clerk Routes ──────────────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Cloudflare Agents URL (for frontend API calls) ───────
NEXT_PUBLIC_AGENTS_URL=https://jobric-agents.YOUR_SUBDOMAIN.workers.dev

# ── Google OAuth (for Gmail API + user login) ─────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Must exactly match an Authorized redirect URI in the Google OAuth client.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ── Gmail token encryption ────────────────────────────────
# Base64-encoded 32-byte key used for AES-GCM encryption of the
# Gmail refresh_token at rest. Generate with: openssl rand -base64 32
GMAIL_TOKEN_KEY=your-base64-32-byte-key

# ── Runtime ───────────────────────────────────────────────
NODE_ENV=development

# ── Monitoring (optional, can leave blank in development) ─
# Sentry: https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=https://your-sentry-dsn
# Axiom: https://app.axiom.co → Settings → API Tokens
AXIOM_TOKEN=your-axiom-token
AXIOM_DATASET=jobric-api

# ── Cloudflare Agents (set via `wrangler secret put`) ─────
# These are NOT set in .env — they are Cloudflare Worker secrets.
# See wrangler secret commands below:
#   wrangler secret put ANTHROPIC_API_KEY --config apps/agents/wrangler.toml
#   wrangler secret put CLERK_SECRET_KEY --config apps/agents/wrangler.toml
#
# CLERK_WEBHOOK_SECRET — svix signing secret for the /webhooks/clerk endpoint
# on the agents Worker. Get it from Clerk Dashboard → Webhooks → your endpoint
# → Signing Secret (starts with `whsec_`). Configure the Clerk endpoint URL as
# https://<your-worker-host>/webhooks/clerk and subscribe to user.created,
# user.updated, user.deleted.
#   wrangler secret put CLERK_WEBHOOK_SECRET --config apps/agents/wrangler.toml
